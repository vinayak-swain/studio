
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for improved readability and reusability.

    /**
     * Checks if the current request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Validates that the requesting user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description
     *   Secures user profile documents. A user can create their own profile, and once
     *   created, only that user can read, update, or delete it.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Disallow listing all users to prevent user enumeration.

      // A user can create their own profile document.
      // The document's internal `id` must match the user's auth UID for integrity.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // The owner can update their profile.
      // The internal `id` field must not be changed after creation.
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;

      // The owner can delete their profile document.
      allow delete: if isOwner(userId);

      /**
       * @description
       *   Secures the repositories subcollection for each user.
       * @path
       *   /users/{userId}/repositories/{repoId}
       */
      match /repositories/{repoId} {
        // Only the owner can list or get their own repositories.
        allow list, get: if isOwner(userId);

        // The owner can create a new repository.
        // The new repository data must include the owner's ID.
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;

        // The owner can update or delete their own repository.
        allow update, delete: if isOwner(userId);
      }
    }
  }
}
